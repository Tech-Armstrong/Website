quot;btn_margin&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;top&quot;:&quot;&quot;,&quot;right&quot;:&quot;&quot;,&quot;bottom&quot;:&quot;&quot;,&quot;left&quot;:&quot;&quot;,&quot;isLinked&quot;:true},&quot;btn_margin_tablet&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;top&quot;:&quot;&quot;,&quot;right&quot;:&quot;&quot;,&quot;bottom&quot;:&quot;&quot;,&quot;left&quot;:&quot;&quot;,&quot;isLinked&quot;:true},&quot;btn_margin_mobile&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;top&quot;:&quot;&quot;,&quot;right&quot;:&quot;&quot;,&quot;bottom&quot;:&quot;&quot;,&quot;left&quot;:&quot;&quot;,&quot;isLinked&quot;:true},&quot;btn_padding&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;top&quot;:&quot;&quot;,&quot;right&quot;:&quot;&quot;,&quot;bottom&quot;:&quot;&quot;,&quot;left&quot;:&quot;&quot;,&quot;isLinked&quot;:true},&quot;btn_padding_tablet&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;top&quot;:&quot;&quot;,&quot;right&quot;:&quot;&quot;,&quot;bottom&quot;:&quot;&quot;,&quot;left&quot;:&quot;&quot;,&quot;isLinked&quot;:true},&quot;btn_padding_mobile&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;top&quot;:&quot;&quot;,&quot;right&quot;:&quot;&quot;,&quot;bottom&quot;:&quot;&quot;,&quot;left&quot;:&quot;&quot;,&quot;isLinked&quot;:true},&quot;ekit_we_effect_on&quot;:&quot;none&quot;}\" data-widget_type=\"counsolve_choose_us.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t    \r\n        \r\n    <!-- chooseus-style-five -->\r\n    <section class=\"chooseus-style-five counsolve-about-section p-0 m-0\">                    \r\n        <div class=\"four-item-carousel choose-four-item-carousel owl-carousel owl-theme  owl-nav-none\" id=\"yt-choose-slider\" data-slider=\"{&quot;infinite&quot;:true,&quot;autoplay&quot;:true,&quot;autoplaySpeed&quot;:&quot;2500&quot;,&quot;dots&quot;:true,&quot;nav&quot;:false,&quot;item_gap&quot;:30,&quot;item_show&quot;:4}\">\r\n                        <div class=\"chooseus-block-three\">\r\n                <div class=\"inner-box\">\r\n                    <span class=\"count-text\">01</span>\r\n                    <h3>Dynamic Challenges</h3>\r\n                    <p>Be part of a fast-paced, innovative workplace where new challenges are met with creative and strategic solutions.</p>\r\n                </div>\r\n            </div>\r\n                        <div class=\"chooseus-block-three\">\r\n                <div class=\"inner-box\">\r\n                    <span class=\"count-text\">02</span>\r\n                    <h3>Growth-Oriented Environment: </h3>\r\n                    <p>Develop skills and gain experiences that pave the way for a successful career.</p>\r\n                </div>\r\n            </div>\r\n                        <div class=\"chooseus-block-three\">\r\n                <div class=\"inner-box\">\r\n                    <span class=\"count-text\">03</span>\r\n                    <h3>Supportive Culture</h3>\r\n                    <p>We help you identify and refine your strengths while addressing areas for improvement.</p>\r\n                </div>\r\n            </div>\r\n                        <div class=\"chooseus-block-three\">\r\n                <div class=\"inner-box\">\r\n                    <span class=\"count-text\">04</span>\r\n                    <h3>Creative Opportunities</h3>\r\n                    <p>At Armstrong Capital, we welcome fresh ideas and diverse perspectives, ensuring that no day feels stagnant.</p>\r\n                </div>\r\n            </div>\r\n                        <div class=\"chooseus-block-three\">\r\n                <div class=\"inner-box\">\r\n                    <span class=\"count-text\">05</span>\r\n                    <h3>Team Collaboration</h3>\r\n                    <p>Work alongside a vibrant team that combines intellectual, technical, and interpersonal skills to help you grow professionally and personally.</p>\r\n                </div>\r\n            </div>\r\n                        <div class=\"chooseus-block-three\">\r\n                <div class=\"inner-box\">\r\n                    <span class=\"count-text\">06</span>\r\n                    <h3>Work-Life Balance</h3>\r\n                    <p>We believe in balancing productivity and fun, creating an environment where you can thrive without burnout.</p>\r\n                </div>\r\n            </div>\r\n                    </div>\r\n    </section>\r\n    <!-- chooseus-style-five end -->    \r\n    \r\n    \t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t</div>\n\t\t\t\t\t</div>\n\t\t</section>\n\t\t\t\t\t</div>\n\t\t</div>\n\t\t\t\t\t</div>\n\t\t</section>\n\t\t\t\t<section class=\"elementor-section elementor-top-section elementor-element elementor-element-8d1ebf2 elementor-section-full_width elementor-section-height-default elementor-section-height-default\" data-id=\"8d1ebf2\" data-element_type=\"section\" data-e-type=\"section\" data-settings=\"{&quot;background_background&quot;:&quot;classic&quot;,&quot;ekit_has_onepagescroll_dot&quot;:&quot;yes&quot;}\">\n\t\t\t\t\t\t<div class=\"elementor-container elementor-column-gap-default\">\n\t\t\t\t\t<div class=\"elementor-column elementor-col-100 elementor-top-column elementor-element elementor-element-552beed\" data-id=\"552beed\" data-element_type=\"column\" data-e-type=\"column\">\n\t\t\t<div class=\"elementor-widget-wrap elementor-element-populated\">\n\t\t\t\t<div class=\"elementor-element elementor-element-b5c060d e-grid e-con-boxed e-con e-parent\" data-id=\"b5c060d\" data-element_type=\"container\" data-e-type=\"container\" data-settings=\"{&quot;ekit_has_onepagescroll_dot&quot;:&quot;yes&quot;}\">\n\t\t\t\t\t<div class=\"e-con-inner\">\n\t\t<div class=\"elementor-element elementor-element-fe15263 e-grid e-con-full quote-area e-con e-child\" data-id=\"fe15263\" data-element_type=\"container\" data-e-type=\"container\" data-settings=\"{&quot;ekit_has_onepagescroll_dot&quot;:&quot;yes&quot;}\">\n\t\t\t\t<div class=\"elementor-element elementor-element-77784e7 inner-box elementor-widget elementor-widget-text-editor\" data-id=\"77784e7\" data-element_type=\"widget\" data-e-type=\"widget\" data-settings=\"{&quot;ekit_we_effect_on&quot;:&quot;none&quot;}\" data-widget_type=\"text-editor.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t\t\t\t\t<div class=\"home-quote-area\"><div class=\"icon-box\"> </div><h5>Choose A Job You Love,</h5><h5>And You Will Never Have To Work A Day In Your Life.</h5><div><em>Confucius</em></div></div>\t\t\t\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t</div>\n\t\t\t\t\t</div>\n\t\t</section>\n\t\t\t\t</div>\n\t\t",
