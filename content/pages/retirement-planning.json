&quot;:&quot;none&quot;}\" data-widget_type=\"counsolve_icon_box.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t       \n               \n        <div class=\"info-block-one town-icon-box\">\n            <div class=\"inner-box\">\n                <div class=\"upper-box\">\n                    <div class=\"light-icon town-icon town-icons\">\n                    \t\t\t\t\t\t\t\t                                            </div>\n                    <div class=\"town-title\"><h3>Growth <br>Component</h3></div>\n                    <div class=\"town-text\"><p>Given that your retirement could extend longer than expected, maintaining growth in your portfolio is essential. The growth component of your plan is designed to outpace inflation through a diversified portfolio. Profits from this growth are funnelled into your salary component, creating a consistent income stream over time. </p></div>\n                </div>\n                <div class=\"lower-content\">\n                                        <div class=\"link te-btn\">\n                        <a href=\"\" class=\"te-thm-btn\"><span>Read More</span></a>\n                    </div>\n                </div>\n            </div>\n        </div>\n        \n\t\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"elementor-element elementor-element-017d9be elementor-widget elementor-widget-counsolve_icon_box\" data-id=\"017d9be\" data-element_type=\"widget\" data-e-type=\"widget\" data-settings=\"{&quot;btn_margin&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;top&quot;:&quot;&quot;,&quot;right&quot;:&quot;&quot;,&quot;bottom&quot;:&quot;&quot;,&quot;left&quot;:&quot;&quot;,&quot;isLinked&quot;:true},&quot;btn_margin_tablet&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;top&quot;:&quot;&quot;,&quot;right&quot;:&quot;&quot;,&quot;bottom&quot;:&quot;&quot;,&quot;left&quot;:&quot;&quot;,&quot;isLinked&quot;:true},&quot;btn_margin_mobile&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;top&quot;:&quot;&