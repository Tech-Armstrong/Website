quot;:&quot;&quot;,&quot;isLinked&quot;:true},&quot;ekit_we_effect_on&quot;:&quot;none&quot;}\" data-widget_type=\"counsolve_icon_box.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t       \n               \n        <div class=\"info-block-one town-icon-box\">\n            <div class=\"inner-box\">\n                <div class=\"upper-box\">\n                    <div class=\"light-icon town-icon town-icons\">\n                    \t\t\t\t\t\t\t\t                                            </div>\n                    <div class=\"town-title\"><h3>Ongoing Portfolio<br> Management</h3></div>\n                    <div class=\"town-text\"><p>We prioritize stability during market volatility by leveraging debt funds as secondary reserves, reducing the need to sell equities at a loss. Balanced portfolios offer protection during downturns, preserving wealth and maintaining your financial security through challenging times.</p></div>\n                </div>\n                <div class=\"lower-content\">\n                                        <div class=\"link te-btn\">\n                        <a href=\"\" class=\"te-thm-btn\"><span>Read More</span></a>\n                    </div>\n                </div>\n            </div>\n        </div>\n        \n\t\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"elementor-element elementor-element-8d2413f elementor-widget elementor-widget-counsolve_icon_box\" data-id=\"8d2413f\" data-element_type=\"widget\" data-e-type=\"widget\" data-settings=\"{&quot;btn_margin&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;top&quot;:&quot;&quot;,&quot;right&quot;:&quot;&quot;,&quot;bottom&quot;:&quot;&quot;,&quot;left&quot;:&quot;&quot;,&quot;isLinked&quot;:true},&quot;btn_margin_tablet&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;top&quot;:&quot;&quot;,&quot;right&quot;:&quot;&quot;,&quot;bottom&quot;:&quot;&quot;,&quot;left&quot;:&quot;&quot;,&quot;isLinked&quot;:true},&quot;btn_margin_mobile&quot;:{&quot;unit&quot;:&q