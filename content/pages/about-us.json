    </div>\n    </section>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t</div>\n\t\t\t\t<div class=\"elementor-column elementor-col-50 elementor-inner-column elementor-element elementor-element-6f5872a3\" data-id=\"6f5872a3\" data-element_type=\"column\" data-e-type=\"column\">\n\t\t\t<div class=\"elementor-widget-wrap elementor-element-populated\">\n\t\t\t\t\t\t<div class=\"elementor-element elementor-element-47c68d8b elementor-widget elementor-widget-counsolve_hero_title\" data-id=\"47c68d8b\" data-element_type=\"widget\" data-e-type=\"widget\" data-settings=\"{&quot;ekit_we_effect_on&quot;:&quot;none&quot;}\" data-widget_type=\"counsolve_hero_title.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t    \n    <div class=\"te-box-title sec-title \">        \n        \t\t<h2 class=\"te_title counsolve-size-default\">Welcome to Armstrong:<br>Strategic Wealth Stewardship </h2>        \n                <div class=\"normal__text text-box\">\n            <p><p>At Armstrong, we go beyond wealth management—we are dedicated to the strategic stewardship of your financial future. Our client-centric approach is designed around your unique goals, backed by our deep expertise in financial planning.</p><p> </p><p>We pride ourselves on delivering personalized, transparent, and comprehensive financial services that not only grow your wealth but also preserve it for generations to come. With Armstrong, you are more than just a client; you are a partner in a lifelong journey toward financial security and lasting success.</p></p>\n        </div>\n                \n    </div>     \n    \n    \t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t</div>\n\t\t\t\t\t</div>\n\t\t</section>\n\t\t\t\t\t</div>\n\t\t</div>\n\t\t\t\t\t</div>\n\t\t</section>\n\t\t\t\t<section class=\"elementor-section elementor-top-section elementor-element elementor-element-1ed78ecf elementor-section-full_width elementor-section-height-default elementor-section-height-default\" data-id=\"1ed78ecf\" data-element_type=\"section\" data-e-type=\"section\" data-settings=\"{&quot;background_background&quot;:&quot;classic&quot;,&quot;ekit_has_onepagescroll_dot&quot;:&quot;yes&quot;}\">\n\t\t\t\t\t\t<div class=\"elementor-container elementor-column-gap-default\">\n\t\t\t\t\t<div class=\"elementor-column elementor-col-100 elementor-top-column elementor-element elementor-element-52eb6acf\" data-id=\"52eb6acf\" data-element_type=\"column\" data-e-type=\"column\">\n\t\t\t<div class=\"elementor-widget-wrap elementor-element-populated\">\n\t\t\t\t\t\t<section class=\"elementor-section elementor-inner-section elementor-element elementor-element-1c15b954 elementor-section-full_width elementor-section-height-default elementor-section-height-default\" data-id=\"1c15b954\" data-element_type=\"section\" data-e-type=\"section\" data-settings=\"{&quot;ekit_has_onepagescroll_dot&quot;:&quot;yes&quot;}\">\n\t\t\t\t\t\t<div class=\"elementor-container elementor-column-gap-default\">\n\t\t\t\t\t<div class=\"elementor-column elementor-col-100 elementor-inner-column elementor-element elementor-element-d4883aa\" data-id=\"d4883aa\" data-element_type=\"column\" data-e-type=\"column\">\n\t\t\t<div class=\"elementor-widget-wrap elementor-element-populated\">\n\t\t\t\t\t\t<div class=\"elementor-element elementor-element-552e2eab elementor-widget elementor-widget-counsolve_hero_title\" data-id=\"552e2eab\" data-element_type=\"widget\" data-e-type=\"widget\" data-settings=\"{&quot;ekit_we_effect_on&quot;:&quot;none&quot;}\" data-widget_type=\"counsolve_hero_title.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t    \n    <div class=\"te-box-title sec-title \">        \n        \t\t<h2 class=\"te_title counsolve-size-default\">Why Choose Us</h2>        \n                <div class=\"normal__text text-box\">\n            <p><p><span class=\"NormalTextRun SCXW130183232 BCX0\">We believe that excellence in wealth management begins with a strategy </span><span class=\"NormalTextRun SCXW130183232 BCX0\">that’s</span><span class=\"NormalTextRun SCXW130183232 BCX0\"> as unique as you are. Our commitment is to </span><span class=\"NormalTextRun SCXW130183232 BCX0\">craft</span><span class=\"NormalTextRun SCXW130183232 BCX0\"> solutions that align with your aspirations, guiding you every step of the way toward achieving your financial dreams.</span></p></p>\n        </div>\n                \n    </div>     \n    \n    \t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t</div>\n\t\t\t\t\t</div>\n\t\t</section>\n\t\t\t\t<section class=\"elementor-section elementor-inner-section elementor-element elementor-element-1a42b393 elementor-section-full_width elementor-section-height-default elementor-section-height-default\" data-id=\"1a42b393\" data-element_type=\"section\" data-e-type=\"section\" data-settings=\"{&quot;ekit_has_onepagescroll_dot&quot;:&quot;yes&quot;}\">\n\t\t\t\t\t\t<div class=\"elementor-container elementor-column-gap-default\">\n\t\t\t\t\t<div class=\"elementor-column elementor-col-100 elementor-inner-column elementor-element elementor-element-49d54b89\" data-id=\"49d54b89\" data-element_type=\"column\" data-e-type=\"column\">\n\t\t\t<div class=\"elementor-widget-wrap elementor-element-populated\">\n\t\t\t\t\t\t<div class=\"elementor-element elementor-element-2d2fe84e elementor-widget elementor-widget-counsolve_choose_us\" data-id=\"2d2fe84e\" data-element_type=\"widget\" data-e-type=\"widget\" data-settings=\"{&quot;counsolve_layout_margin&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;top&quot;:&quot;&quot;,&quot;right&quot;:&quot;&quot;,&quot;bottom&quot;:&quot;&quot;,&quot;left&quot;:&quot;&quot;,&quot;isLinked&quot;:true},&quot;counsolve_layout_margin_tablet&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;top&quot;:&quot;&quot;,&quot;right&quot;:&quot;&quot;,&quot;bottom&quot;:&quot;&quot;,&quot;left&quot;:&quot;&quot;,&quot;isLinked&quot;:true},&quot;counsolve_layout_margin_mobile&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;top&quot;:&quot;&quot;,&quot;right&quot;:&quot;&quot;,&quot;bottom&quot;:&quot;&quot;,&quot;left&quot;:&quot;&quot;,&quot;isLinked&quot;:true},&quot;counsolve_layout_padding&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;top&quot;:&quot;&quot;,&quot;right&quot;:&quot;&quot;,&quot;bottom&quot;:&quot;&quot;,&quot;left&quot;:&quot;&quot;,&quot;isLinked&quot;:true},&quot;counsolve_layout_padding_tablet&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;top&quot;:&quot;&quot;,&quot;right&quot;:&quot;&quot;,&quot;bottom&quot;:&quot;&quot;,&quot;left&quot;:&quot;&quot;,&quot;isLinked&quot;:true},&quot;counsolve_layout_padding_mobile&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;top&quot;:&quot;&quot;,&quot;right&quot;:&quot;&quot;,&quot;bottom&quot;:&quot;&quot;,&quot;left&quot;:&quot;&quot;,&quot;isLinked&quot;:true},&quot;btn_margin&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;top&quot;:&quot;&quot;,&quot;right&quot;:&quot;&quot;,&quot;bottom&quot;:&quot;&quot;,&quot;left&quot;:&quot;&quot;,&quot;isLinked&quot;:true},&quot;btn_margin_tablet&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;top&quot;:&quot;&quot;,&quot;right&quot;:&quot;&quot;,&quot;bottom&quot;:&quot;&quot;,&quot;left&quot;:&quot;&quot;,&quot;isLinked&quot;:true},&quot;btn_margin_mobile&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;top&quot;:&quot;&quot;,&quot;right&quot;:&quot;&quot;,&quot;bottom&quot;:&quot;&quot;,&quot;left&quot;:&quot;&quot;,&quot;isLinked&quot;:true},&quot;btn_padding&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;top&quot;:&quot;&quot;,&quot;right&quot;:&quot;&quot;,&quot;bottom&quot;:&quot;&quot;,&quot;left&quot;:&quot;&quot;,&quot;isLinked&quot;:true},&quot;btn_padding_tablet&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;top&quot;:&quot;&quot;,&quot;right&quot;:&quot;&quot;,&quot;bottom&quot;:&quot;&quot;,&quot;left&quot;:&quot;&quot;,&quot;isLinked&quot;:true},&quot;btn_padding_mobile&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;top&quot;:&quot;&quot;,&quot;right&quot;:&quot;&quot;,&quot;bottom&quot;:&quot;&quot;,&quot;left&quot;:&quot;&quot;,&quot;isLinked&quot;:true},&quot;ekit_we_effect_on&quot;:&quot;none&quot;}\" data-widget_type=\"counsolve_choose_us.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t    \r\n        \r\n    <!-- chooseus-style-five -->\r\n    <section class=\"chooseus-style-five counsolve-about-section p-0 m-0\">                    \r\n        <div class=\"four-item-carousel choose-four-item-carousel owl-carousel owl-theme  owl-nav-none\" id=\"yt-choose-slider\" data-slider=\"{&quot;infinite&quot;:true,&quot;autoplay&quot;:true,&quot;autoplaySpeed&quot;:&quot;2500&quot;,&quot;dots&quot;:true,&quot;nav&quot;:false,&quot;item_gap&quot;:30,&quot;item_show&quot;:4}\">\r\n                        <div class=\"chooseus-block-three\">\r\n                <div class=\"inner-box\">\r\n                    <span class=\"count-text\">01</span>\r\n                    <h3>Lifelong Financial   <span>Guidance</span></h3>\r\n                    <p>Armstrong is an Investment Management firm providing professional insights and strategic advice on all facets of the financial needs of an individual.</p>\r\n                </div>\r\n            </div>\r\n                        <div class=\"chooseus-block-three\">\r\n                <div class=\"inner-box\">\r\n                    <span class=\"count-text\">02</span>\r\n                    <h3>Tailored Financial  <span>Solutions</span></h3>\r\n                    <p>Our expertise spans a wide spectrum of financial services, enabling us to provide tailored solutions that align with your unique financial objectives.</p>\r\n                </div>\r\n            </div>\r\n                        <div class=\"chooseus-block-three\">\r\n                <div class=\"inner-box\">\r\n                    <span class=\"count-text\">03</span>\r\n                    <h3>Professional Insights  <span>Strategic Advice</span></h3>\r\n                    <p>Expert financial guidance to navigate complexities, make informed decisions, and achieve success with a seasoned team deeply understanding the financial landscape. </p>\r\n                </div>\r\n            </div>\r\n                        <div class=\"chooseus-block-three\">\r\n                <div class=\"inner-box\">\r\n                    <span class=\"count-text\">04</span>\r\n                    <h3>Preserving and <span>Growing Your Capital </span></h3>\r\n                    <p>Capital preservation is our priority. With a meticulous, risk-minimizing approach, we aim for steady returns, helping your wealth grow and financial dreams come true.</p>\r\n                </div>\r\n            </div>\r\n                    </div>\r\n    </section>\r\n    <!-- chooseus-style-five end -->    \r\n    \r\n    \t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t</div>\n\t\t\t\t\t</div>\n\t\t</section>\n\t\t\t\t\t</div>\n\t\t</div>\n\t\t\t\t\t</div>\n\t\t</section>\n\t\t\t\t<section class=\"elementor-section elementor-top-section elementor-element elementor-element-8d1ebf2 elementor-section-full_width elementor-section-height-default elementor-section-height-default\" data-id=\"8d1ebf2\" data-element_type=\"section\" data-e-type=\"section\" data-settings=\"{&quot;background_background&quot;:&quot;classic&quot;,&quot;ekit_has_onepagescroll_dot&quot;:&quot;yes&quot;}\">\n\t\t\t\t\t\t<div class=\"elementor-container elementor-column-gap-default\">\n\t\t\t\t\t<div class=\"elementor-column elementor-col-100 elementor-top-column elementor-element elementor-element-552beed\" data-id=\"552beed\" data-element_type=\"column\" data-e-type=\"column\">\n\t\t\t<div class=\"elementor-widget-wrap elementor-element-populated\">\n\t\t\t\t<div class=\"elementor-element elementor-element-b5c060d e-grid e-con-boxed e-con e-parent\" data-id=\"b5c060d\" data-element_type=\"container\" data-e-type=\"container\" data-settings=\"{&quot;ekit_has_onepagescroll_dot&quot;:&quot;yes&quot;}\">\n\t\t\t\t\t<div class=\"e-con-inner\">\n\t\t<div class=\"elementor-element elementor-element-fe15263 e-grid e-con-full quote-area e-con e-child\" data-id=\"fe15263\" data-element_type=\"container\" data-e-type=\"container\" data-settings=\"{&quot;ekit_has_onepagescroll_dot&quot;:&quot;yes&quot;}\">\n\t\t\t\t<div class=\"elementor-element elementor-element-77784e7 inner-box elementor-widget elementor-widget-text-editor\" data-id=\"77784e7\" data-element_type=\"widget\" data-e-type=\"widget\" data-settings=\"{&quot;ekit_we_effect_on&quot;:&quot;none&quot;}\" data-widget_type=\"text-editor.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t\t\t\t\t<div class=\"home-quote-area\"><div class=\"icon-box\"> </div><h5><span class=\"TextRun SCXW35742131 BCX0\" lang=\"EN-IN\" xml:lang=\"EN-IN\" data-contrast=\"auto\"><span class=\"NormalTextRun SCXW35742131 BCX0\"><span class=\"TextRun SCXW163661503 BCX0\" lang=\"EN-IN\" xml:lang=\"EN-IN\" data-contrast=\"auto\"><span class=\"NormalTextRun SCXW163661503 BCX0\">Successful Investing Is About Managing Risk, Not Avoiding It.</span></span></span></span></h5><div><em><span class=\"designation SCXW35742131 BCX0\"><span class=\"TextRun SCXW208200875 BCX0\" lang=\"EN-IN\" xml:lang=\"EN-IN\" data-contrast=\"auto\"><span class=\"NormalTextRun SCXW208200875 BCX0\">Benjamin Graham</span></span></span></em></div></div>\t\t\t\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t</div>\n\t\t\t\t\t</div>\n\t\t</section>\n\t\t\t\t</div>\n\t\t",
